<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hotel Subani</title>

<style>
body {
  margin:0;
  font-family: 'Poppins', sans-serif;
  background:#0f0f0f;
  color:white;
}

header {
  display:flex;
  justify-content:space-between;
  padding:15px 30px;
  background:#000;
  position:sticky;
  top:0;
}

.logo {
  color:#ffcc00;
  font-size:22px;
  font-weight:bold;
}

nav a {
  color:white;
  margin:0 10px;
  text-decoration:none;
}

.hero {
  height:90vh;
  background:url('https://images.unsplash.com/photo-1604908176997-125f25cc6f3d') center/cover;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  text-align:center;
}

.hero h1 {
  font-size:50px;
  color:#ffcc00;
}

.btn {
  padding:12px 25px;
  background:#ffcc00;
  color:black;
  text-decoration:none;
  margin:10px;
  border-radius:5px;
  font-weight:bold;
}

.section {
  padding:50px 20px;
  text-align:center;
}

.menu {
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(200px,1fr));
  gap:20px;
}

.card {
  background:#1a1a1a;
  padding:20px;
  border-radius:10px;
  transition:0.3s;
}

.card:hover {
  transform:scale(1.05);
}

.order-box {
  background:#222;
  padding:30px;
  border-radius:10px;
}

input, select {
  padding:10px;
  margin:10px;
  width:80%;
  border:none;
  border-radius:5px;
}

button {
  padding:10px 20px;
  background:#ffcc00;
  border:none;
  font-weight:bold;
  cursor:pointer;
}

iframe {
  width:100%;
  height:300px;
  border:0;
  border-radius:10px;
}

footer {
  background:#000;
  padding:20px;
  text-align:center;
}
</style>

</head>

<body>

<header>
<div class="logo">Hotel Subani</div>
<nav>
<a href="#">Home</a>
<a href="#menu">Menu</a>
<a href="#order">Order</a>
<a href="#contact">Contact</a>
</nav>
</header>

<section class="hero">
<h1>Famous Biryani Spot 🔥</h1>
<p>Authentic Taste | Rich Flavor | Affordable</p>

<a href="tel:09014734244" class="btn">📞 Call Now</a>
<a href="https://wa.me/919014734244" class="btn">💬 WhatsApp Order</a>
</section>

<section class="section">
<h2>About Us</h2>
<p>Hotel Subani is known for its delicious and authentic biryani. We serve fresh, spicy, and flavorful dishes that customers love.</p>
</section>

<section class="section" id="menu">
<h2>Our Menu 🍛</h2>

<div class="menu">
<div class="card">🍗 Chicken Biryani – ₹250</div>
<div class="card">🥩 Mutton Biryani – ₹450</div>
<div class="card">🍛 Mutton Curry – ₹250</div>
<div class="card">🥚 Egg Biryani – ₹200</div>
</div>
</section>

<section class="section" id="order">
<h2>Order Online 🚀</h2>

<div class="order-box">
<input type="text" id="name" placeholder="Your Name"><br>
<input type="text" id="phone" placeholder="Phone Number"><br>

<select id="item">
<option>Chicken Biryani</option>
<option>Mutton Biryani</option>
<option>Mutton Curry</option>
<option>Egg Biryani</option>
</select><br>

<input type="number" id="qty" placeholder="Quantity"><br>

<button onclick="orderNow()">Place Order</button>
</div>
</section>

<section class="section" id="contact">
<h2>Location 📍</h2>

<!-- Replace YOUR_GOOGLE_MAP_LINK -->
<iframe src="https://www.google.com/maps?q=YOUR_GOOGLE_MAP_LINK&output=embed"></iframe>

<p>📞 090147 34244</p>
</section>

<footer>
<p>© 2026 Hotel Subani | All Rights Reserved</p>
</footer>

<script>
function orderNow() {
  let name = document.getElementById("name").value;
  let phone = document.getElementById("phone").value;
  let item = document.getElementById("item").value;
  let qty = document.getElementById("qty").value;

  let msg = `Hello Hotel Subani!%0AName: ${name}%0APhone: ${phone}%0AOrder: ${item}%0AQuantity: ${qty}`;

  window.open(`https://wa.me/919014734244?text=${msg}`, "_blank");
}
</script>

</body>
</html>
